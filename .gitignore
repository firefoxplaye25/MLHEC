## Visual Studio / .NET Core gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image-cache files
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on VFAT chunks
$RECYCLE.BIN/

# VS Code folders and files
.vscode/
.history/
*.code-workspace

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Backup & temp files from merge tools
*.orig
*.bak

# Others
test.txt
scratch/
Build_*/
